#!/bin/bash

export PATH=/var/apps/nodejs_v24/target/bin:$PATH

PID_FILE="${TRIM_PKGVAR}/app.pid"
DATA_DIR="${TRIM_PKGVAR}/data"
MEDIA_PATH_FILE="${TRIM_PKGVAR}/data/media_path.conf"

if [ -z "${TRIM_PKGDIR}" ]; then
    VOL=$(echo "${TRIM_PKGVAR}" | sed 's|/vol\([0-9]*\)/.*|\1|')
    TRIM_PKGDIR="/vol${VOL}/@appcenter/mediahub"
fi

MEDIA_PATH=""
if [ -f "${MEDIA_PATH_FILE}" ]; then
    MEDIA_PATH=$(cat "${MEDIA_PATH_FILE}" | tr -d '[:space:]')
fi

start_process() {
    if status; then
        return 0
    fi

    mkdir -p "${DATA_DIR}"
    mkdir -p "${TRIM_PKGVAR}/logs"
    
    if [ -n "${MEDIA_PATH}" ]; then
        mkdir -p "${MEDIA_PATH}"
        chmod 777 "${MEDIA_PATH}"
    fi
    
    cd "${TRIM_PKGDIR}/www/server"
    
    NODE_ENV=production \
    TRIM_PKGVAR="${TRIM_PKGVAR}" \
    TRIM_PKGDIR="${TRIM_PKGDIR}" \
    MEDIA_PATH="${MEDIA_PATH}" \
    NITRO_PRESET=node-server \
    PORT=3030 \
    bash -c 'exec -a MediaHub node "$1"' _ "${TRIM_PKGDIR}/www/server/index.mjs" &
    
    printf "%s" "$!" > ${PID_FILE}
    return 0
}

stop_process() {
    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            return
        fi

        kill -TERM ${pid} 2>/dev/null

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done

        if check_process "${pid}"; then
            kill -KILL ${pid} 2>/dev/null
            sleep 1
            rm -f "${PID_FILE}"
        else
            rm -f "${PID_FILE}"
        fi
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi    
    fi

    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then 
        exit 0
    else 
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
